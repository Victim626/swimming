<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.usbtj.springboot.swimming.mapper.TimeSlotMapper">
    
    <resultMap id="timeSlotMap" type="com.usbtj.springboot.swimming.entity.TimeSlot">
        <id property="id" column="id"/>
        <result property="slotName" column="slot_name"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="maxCapacity" column="max_capacity"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="isActive" column="is_active"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findAll" resultMap="timeSlotMap">
        SELECT * FROM time_slots WHERE is_active = 1 ORDER BY sort_order ASC
    </select>

    <select id="findById" resultMap="timeSlotMap">
        SELECT * FROM time_slots WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO time_slots (slot_name, start_time, end_time, max_capacity, sort_order, is_active)
        VALUES (#{slotName}, #{startTime}, #{endTime}, #{maxCapacity}, #{sortOrder}, #{isActive})
    </insert>

    <update id="update">
        UPDATE time_slots 
        SET slot_name = #{slotName},
            start_time = #{startTime},
            end_time = #{endTime},
            max_capacity = #{maxCapacity},
            sort_order = #{sortOrder},
            is_active = #{isActive}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM time_slots WHERE id = #{id}
    </delete>
    
</mapper>
